{
    "[prisma]": {
        "editor.defaultFormatter": "Prisma.prisma"
    },
    "breadcrumbs.enabled": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "discord.detailsDebugging": "🐛 {file_name} [L{current_line}/{total_lines}]",
    "discord.detailsEditing": "📝 {file_name} [L{current_line}/{total_lines}]",
    "discord.detailsIdling": "☕ Idling",
    "discord.lowerDetailsDebugging": "📁 {workspace}",
    "discord.lowerDetailsEditing": "📁 {workspace}",
    "discord.lowerDetailsIdling": "{empty}",
    "editor.accessibilitySupport": "off",
    "editor.cursorSmoothCaretAnimation": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontLigatures": true,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": true,
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.tabCompletion": "on",
    "editor.unicodeHighlight.invisibleCharacters": false,
    "emmet.includeLanguages": {
        "vue-html": "html",
        "vue": "html"
    },
    "emmet.syntaxProfiles": {
        "vue-html": "html",
        "vue": "html"
    },
    "emmet.triggerExpansionOnTab": true,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js, ${capture}.meta.ts, ${capture}.utils.ts",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts, ${capture}.meta.js, ${capture}.utils.js",
        "*.jsx": "${capture}.js, ${capture}.css, ${capture}.scss, ${capture}.sass, ${capture}.less, ${capture}.stylus, ${capture}.test.js",
        "*.tsx": "${capture}.ts, ${capture}.css, ${capture}.scss, ${capture}.sass, ${capture}.less, ${capture}.stylus, ${capture}.test.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml"
    },
    "files.associations": {
        ".env": "properties"
    },
    "git.autofetch": true,
    "git.confirmSync": false,
    "material-icon-theme.activeIconPack": "vue",
    "omnisharp.useModernNet": false,
    "prettier.tabWidth": 4,
    "screencastMode.fontSize": 30,
    "screencastMode.onlyKeyboardShortcuts": true,
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.integrated.gpuAcceleration": "off",
    "typescript.tsserver.experimental.enableProjectDiagnostics": true,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "window.autoDetectColorScheme": true,
    "window.commandCenter": false,
    "window.title": "${rootName}${separator}${appName}",
    "window.titleBarStyle": "custom",
    "window.titleSeparator": " | ",
    "window.zoomLevel": 1,
    "workbench.colorTheme": "poimandres",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.scrollToSwitchTabs": true,
    "workbench.editor.tabCloseButton": "off",
    "workbench.iconTheme": "quill-icons",
    "workbench.layoutControl.type": "menu",
    "workbench.preferredDarkColorTheme": "poimandres",
    "workbench.preferredLightColorTheme": "Min Light",
    "workbench.productIconTheme": "fluent-icons",
    "workbench.sideBar.location": "left",
    "workbench.tree.indent": 20
}
